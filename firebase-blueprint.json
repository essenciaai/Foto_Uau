{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and subscription data",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "subscriptionStatus": { "type": "string", "enum": ["free", "pro", "enterprise"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "ProcessedImage": {
      "title": "Processed Image",
      "description": "Metadata for images processed by the user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "originalUrl": { "type": "string" },
        "processedUrl": { "type": "string" },
        "prompt": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "originalUrl", "processedUrl"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/images/{imageId}": {
      "schema": "ProcessedImage",
      "description": "Processed images"
    }
  }
}
